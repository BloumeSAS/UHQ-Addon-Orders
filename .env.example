# ─── UHQ Orders Addon — Variables d'environnement ─────────────────────────────
# Copier ce fichier en .env et ajuster les valeurs.

# Port du microservice orders (par défaut : 3002)
PORT=3002

# URL du panel UHQ
PANEL_URL=http://localhost:8000

# Chemin du fichier JSON servant de base de données
# En production Docker : /app/data/orders-data.json
DB_PATH=./orders-data.json

# Environnement (development | production)
NODE_ENV=development

# Clé API du panel UHQ (Paramètres → Clé API).
# Permet au panel d'appeler les endpoints /api/backup/export et /api/backup/import.
# Laisser vide en développement (backup non protégé).
PANEL_API_KEY=

# ─── Intégration Wallet (OBLIGATOIRE) ─────────────────────────────────────────
# L'addon Orders débite le solde géré par l'addon Wallet.
# Aucun token admin requis : l'addon utilise PANEL_API_KEY (déjà défini ci-dessus)
# pour s'authentifier auprès du Wallet via l'endpoint interne /api/wallet/internal/add.

# URL de base de l'addon Wallet (ex: https://wallet.domaine.com ou http://wallet:3001 en compose)
WALLET_URL=http://localhost:3001
