{
  "name": "Orders",
  "version": "1.1.1",
  "description": "Boutique interne : l'admin gère un catalogue de produits, les utilisateurs passent commande et paient avec leur solde Wallet. Nécessite l'addon Wallet.",
  "icon": "ShoppingCart",
  "author": {
    "name": "Bloume SAS",
    "email": "contact@bloume.fr",
    "url": "https://bloume.fr"
  },
  "homepage": "https://github.com/BloumeSAS/UHQ-Addon-Orders",
  "license": "MIT",
  "repository": "https://github.com/BloumeSAS/UHQ-Addon-Orders",
  "translations": {
    "fr": {
      "addon.orders.nav": "Boutique",
      "addon.orders.navAdmin": "Gestion boutique",
      "addon.orders.summary": "Commandes"
    },
    "en": {
      "addon.orders.nav": "Store",
      "addon.orders.navAdmin": "Store management",
      "addon.orders.summary": "Orders"
    }
  },
  "pages": [
    {
      "path": "/",
      "label": "addon.orders.nav",
      "icon": "ShoppingCart",
      "showInNavbar": false,
      "adminOnly": false
    },
    {
      "path": "/admin",
      "label": "addon.orders.navAdmin",
      "icon": "Store",
      "showInNavbar": true,
      "adminOnly": true
    }
  ],
  "slots": [
    {
      "zone": "topbar",
      "label": "addon.orders.nav",
      "icon": "ShoppingCart",
      "page": "/",
      "adminOnly": false
    }
  ],
  "widgets": [
    {
      "zone": "/",
      "path": "/widget/dashboard",
      "height": 100,
      "label": "addon.orders.summary"
    }
  ],
  "auth": {
    "passJwt": true,
    "passUserInfo": true
  },
  "backup": {
    "exportEndpoint": "/api/backup/export",
    "importEndpoint": "/api/backup/import",
    "authHeader": "X-Panel-Key"
  }
}
